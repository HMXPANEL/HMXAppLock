<resources>
    <style name="Theme.HMXShield" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/bg_primary</item>
    </style>

    <style name="Theme.HMXShield.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_shield_notification</item>
        <item name="postSplashScreenTheme">@style/Theme.HMXShield</item>
    </style>
</resources>
